{
  "kind": "collectionType",
  "collectionName": "testimonials",
  "info": {
    "singularName": "testimonial",
    "pluralName": "testimonials",
    "displayName": "Testimonial",
    "description": "Customer testimonials and reviews"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "author": {
      "type": "string",
      "required": true
    },
    "text": {
      "type": "text",
      "required": true
    },
    "location": {
      "type": "string"
    },
    "trip": {
      "type": "string"
    },
    "rating": {
      "type": "integer",
      "min": 1,
      "max": 5,
      "default": 5,
      "required": true
    },
    "image": {
      "type": "string"
    },

    "isPublished": {
      "type": "boolean",
      "default": true
    }
  }
}